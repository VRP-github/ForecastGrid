.pytest_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checker / linter caches
.mypy_cache/
.pyre/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Airflow runtime artifacts
airflow.db
airflow-webserver.pid
airflow-scheduler.pid
airflow-worker.pid
airflow-triggerer.pid
logs/

