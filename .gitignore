.env
.env.*
*.pem

# OS/editor files
.DS_Store
.idea/
.vscode/

# Project data and generated outputs
*.parquet
*.feather
*.h5
*.hdf5
*.db

# Keep placeholders if you use them
!data/.gitkeep
!notebooks/.gitkeep

